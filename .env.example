# =============================================================================
# OSINT World Feed - Variables de Entorno
# =============================================================================
# Copia este archivo como .env y completa los valores
#
# SIN DOCKER (desarrollo local):
#   La app usa SQLite (archivo backend/prisma/dev.db) y caché en memoria.
#   Solo necesitas Node.js 20+.
#
# CON DOCKER (producción):
#   Usa PostgreSQL + PostGIS + Redis. Ver docker-compose.yml.

# --- Base de Datos (SQLite por defecto, PostgreSQL con Docker) ---
DATABASE_URL="file:./dev.db"
# Para PostgreSQL con Docker: postgresql://osint_user:osint_pass_secure@localhost:5432/osint_feed

# --- JWT ---
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_EXPIRES_IN=7d

# --- APIs Externas (opcional, usa mocks si están vacías) ---
NEWSAPI_KEY=
GDELT_API_URL=https://api.gdeltproject.org/api/v2

# --- Configuración de Colectores ---
COLLECTOR_INTERVAL_MINUTES=5

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=http://localhost:4000

# --- Modo Desarrollo ---
NODE_ENV=development
USE_MOCKS=true

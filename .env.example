# =============================================================================
# OSINT World Feed - Variables de Entorno
# =============================================================================
# Copia este archivo como .env y completa los valores

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=osint_feed
POSTGRES_USER=osint_user
POSTGRES_PASSWORD=osint_pass_secure

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT ---
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_EXPIRES_IN=7d

# --- APIs Externas ---
NEWSAPI_KEY=tu_api_key_de_newsapi
GDELT_API_URL=https://api.gdeltproject.org/api/v2
GDELT_API_KEY=opcional

# --- Configuración de Colectores ---
COLLECTOR_INTERVAL_MINUTES=5
BREAKING_NEWS_INTERVAL_SECONDS=30

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=http://localhost:4000

# --- Modo Desarrollo ---
NODE_ENV=development
USE_MOCKS=true
